// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"dependsOn": [
				"yarn: watch:tsc",
				"yarn: watch:esbuild",
				"yarn: watch:webview"
			],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"type": "shell",
			"command": "yarn run watch:esbuild",
			"group": "build",
			"isBackground": true,
			"label": "yarn: watch:esbuild",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			},
			"problemMatcher": {
				"owner": "esbuild",
				"pattern": {
					"regexp": "^✘ \\[ERROR\\] (.*)$",
					"message": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\] build started$",
					"endsPattern": "^\\[watch\\] build finished$"
				}
			}
		},
		{
			"type": "shell",
			"command": "yarn run watch:tsc",
			"group": "build",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"label": "yarn: watch:tsc",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"type": "shell",
			"command": "yarn run watch:webview",
			"group": "build",
			"isBackground": true,
			"label": "yarn: watch:webview",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			},
			"problemMatcher": {
				"owner": "vite",
				"pattern": {
					"regexp": "^(.*)$",
					"message": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "vite v.* building client environment for production",
					"endsPattern": "built in .*"
				}
			}
		},
		{
			"type": "npm",
			"script": "watch-tests",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"label": "tasks: watch-tests",
			"dependsOn": [
				"watch",
				"npm: watch-tests"
			],
			"problemMatcher": []
		}
	]
}
